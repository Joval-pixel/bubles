API_KEY=cole_sua_chave_api_football_aqui
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026
WORLD_CUP_LIMIT=120
API_FOOTBALL_TIMEZONE=America/Sao_Paulo
TARGET_BOOKMAKERS=Bet365,Betano
# true = mostra somente jogos com odds oficiais das casas acima.
# false = se nenhuma casa acima tiver odds, mostra todos os jogos para nao zerar o radar.
STRICT_TARGET_BOOKMAKERS=true
MAX_ODDS_PAGES=20
# Pausa pequena entre paginas de odds para evitar rate-limit da API-Football.
ODDS_PAGE_DELAY_MS=35
ODDS_PAGE_BATCH_SIZE=4

# Opcional: correcao manual para fixtures que a API-Football devolver com data errada.
# Formato: id=data;id=data
FIXTURE_DATE_OVERRIDES=

# Opcional: usado apenas na pagina /widgets, pois widgets rodam no navegador.
VITE_API_FOOTBALL_WIDGET_KEY=cole_sua_chave_api_football_aqui

# Opcional: links dos botoes Bet365/Betano no site.
# Pode ser link normal, afiliado ou deeplink. Aceita {home}, {away}, {game} e {query}.
VITE_BET365_URL=https://www.bet365.com/
VITE_BETANO_URL=https://www.betano.bet.br/
